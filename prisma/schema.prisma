generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FragranceHouse {
  id         String      @id @default(uuid())
  name       String      @unique
  tier       String
  country    String?
  founded    Int?
  createdAt  DateTime    @default(now())
  fragrances Fragrance[]

  @@map("fragrance_houses")
}

model Fragrance {
  id               String   @id @default(uuid())
  houseId          String
  name             String
  slug             String   @unique
  concentration    String?
  yearReleased     Int?
  perfumer         String?
  description      String?
  retailPriceUsd   Decimal? @db.Decimal(8, 2)
  sizeMl           Int      @default(100)
  gender           String   @default("unisex")
  season           String[]
  occasion         String[]
  longevity        Int?
  sillage          Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  house            FragranceHouse    @relation(fields: [houseId], references: [id])
  notes            FragranceNote[]
  discounterPrices DiscounterPrice[]
  collectionEntries UserCollection[]
  wishlistEntries  UserWishlist[]
  wearLogs         WearLog[]
  communityRatings CommunityRating[]

  @@index([houseId])
  @@map("fragrances")
}

model Note {
  id         String          @id @default(uuid())
  name       String          @unique
  family     String?
  createdAt  DateTime        @default(now())
  fragrances FragranceNote[]

  @@map("notes")
}

model FragranceNote {
  fragranceId String
  noteId      String
  layer       String
  fragrance   Fragrance @relation(fields: [fragranceId], references: [id], onDelete: Cascade)
  note        Note      @relation(fields: [noteId], references: [id])

  @@id([fragranceId, noteId, layer])
  @@map("fragrance_notes")
}

model Discounter {
  id          String            @id @default(uuid())
  name        String            @unique
  baseUrl     String
  network     String?
  affiliateId String?
  prices      DiscounterPrice[]

  @@map("discounters")
}

model DiscounterPrice {
  id           String    @id @default(uuid())
  fragranceId  String
  discounterId String
  priceUsd     Decimal   @db.Decimal(8, 2)
  affiliateUrl String
  inStock      Boolean   @default(true)
  lastSyncedAt DateTime  @default(now())

  fragrance   Fragrance  @relation(fields: [fragranceId], references: [id], onDelete: Cascade)
  discounter  Discounter @relation(fields: [discounterId], references: [id])

  @@unique([fragranceId, discounterId])
  @@map("discounter_prices")
}

model User {
  id          String   @id @default(uuid())
  clerkId     String?  @unique
  username    String   @unique
  displayName String?
  avatarUrl   String?
  bio         String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  collection       UserCollection[]
  wishlist         UserWishlist[]
  wearLogs         WearLog[]
  communityRatings CommunityRating[]

  @@map("users")
}

model UserCollection {
  id            String    @id @default(uuid())
  userId        String
  fragranceId   String
  status        String    @default("owned")
  bottleSizeMl  Int?
  purchasePrice Decimal?  @db.Decimal(8, 2)
  purchaseDate  DateTime?
  rating        Decimal?  @db.Decimal(3, 1)
  notes         String?
  occasions     String[]
  addedAt       DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fragrance Fragrance @relation(fields: [fragranceId], references: [id])

  @@unique([userId, fragranceId])
  @@map("user_collection")
}

model UserWishlist {
  id          String   @id @default(uuid())
  userId      String
  fragranceId String
  priority    Int      @default(3)
  addedAt     DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fragrance Fragrance @relation(fields: [fragranceId], references: [id])

  @@unique([userId, fragranceId])
  @@map("user_wishlist")
}

model WearLog {
  id           String   @id @default(uuid())
  userId       String
  fragranceId  String
  wornDate     DateTime @db.Date
  occasion     String?
  weatherTempF Int?
  weatherDesc  String?
  notes        String?
  createdAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fragrance Fragrance @relation(fields: [fragranceId], references: [id])

  @@map("wear_log")
}

model CommunityRating {
  id          String   @id @default(uuid())
  userId      String
  fragranceId String
  longevity   Int?
  sillage     Int?
  value       Int?
  review      String?
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fragrance Fragrance @relation(fields: [fragranceId], references: [id], onDelete: Cascade)

  @@unique([userId, fragranceId])
  @@map("community_ratings")
}